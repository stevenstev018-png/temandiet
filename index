  function formatValue(val, unit) {
    if (unit === 'level') return `level ${val}`;
    if (unit === '') return val;
    if (unit === 'kcal') return `${val.toLocaleString('id-ID')} ${unit}`;
    return `${val} ${unit}`;
  }

  function calculateTrend(history) {
    if (!history || history.length < 2) return { class: 'trend-neutral', text: '—' };
    const latest = history[history.length - 1].value;
    const previous = history[history.length - 2].value;
    const diff = latest - previous;
    if (Math.abs(diff) < 0.1) return { class: 'trend-neutral', text: '→' };
    if (diff > 0) return { class: 'trend-up', text: `↑ ${diff.toFixed(1)}` };
    return { class: 'trend-down', text: `↓ ${Math.abs(diff).toFixed(1)}` };
  }

