<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Teman Diet — Prototype</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  :root {
    --bg: #0F1419;
    --bg-card: #1A1F2A;
    --bg-elevated: #232936;
    --text: #F5F1E8;
    --text-muted: #8B92A0;
    --accent: #E8B647;
    --accent-soft: rgba(232, 182, 71, 0.12);
    --success: #6FCF97;
    --danger: #EB5757;
    --warning: #F2994A;
    --border: rgba(255,255,255,0.06);
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    justify-content: center;
    overflow-x: hidden;
  }

  /* iPhone Frame */
  .phone {
    width: 100%;
    max-width: 414px;
    min-height: 100vh;
    background: var(--bg);
    position: relative;
    padding-bottom: 80px;
  }

  /* Status Bar */
  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px 8px;
    font-size: 14px;
    font-weight: 600;
  }

  /* Header */
  .header {
    padding: 16px 24px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .logo span {
    color: var(--accent);
    font-style: italic;
  }

  .day-counter {
    background: var(--accent-soft);
    color: var(--accent);
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  /* Pages */
  .page { display: none; padding: 0 24px 24px; animation: fadeIn 0.3s ease; }
  .page.active { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Hero Stats Card */
  .hero-card {
    background: linear-gradient(135deg, #1F2A3A 0%, #2A3447 100%);
    border-radius: 24px;
    padding: 28px 24px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .hero-card::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -30%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, var(--accent-soft) 0%, transparent 70%);
  }

  .hero-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .hero-weight {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 56px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
    letter-spacing: -2px;
  }

  .hero-weight span {
    font-size: 24px;
    color: var(--text-muted);
    font-weight: 400;
  }

  .hero-progress {
    margin-top: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .progress-item {
    flex: 1;
  }

  .progress-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .progress-value {
    font-size: 18px;
    font-weight: 700;
    color: var(--accent);
  }

  /* Daily Stats */
  .stats-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 20px;
  }

  .stat-card {
    background: var(--bg-card);
    padding: 18px;
    border-radius: 16px;
    border: 1px solid var(--border);
  }

  .stat-card.wide { grid-column: 1 / -1; }

  .stat-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 700;
    font-family: 'Playfair Display', Georgia, serif;
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-suffix {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 400;
  }

  .stat-bar {
    height: 4px;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 10px;
  }

  .stat-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.5s ease;
  }

  /* Section Title */
  .section-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    margin: 24px 0 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-title::before {
    content: "";
    width: 16px;
    height: 1px;
    background: var(--accent);
  }

  /* Quick Actions */
  .quick-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 20px;
  }

  .quick-btn {
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 14px 16px;
    border-radius: 14px;
    font-size: 14px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
  }

  .quick-btn:active { transform: scale(0.97); background: var(--bg-elevated); }
  .quick-btn-icon { font-size: 18px; }

  /* Section title row with edit button */
  .section-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 24px 0 12px;
  }

  .edit-toggle {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 6px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .edit-toggle.active {
    background: var(--accent);
    color: #1A1F2A;
    border-color: var(--accent);
  }

  /* Quick add item in edit mode */
  .quick-btn {
    position: relative;
  }

  .quick-btn.edit-mode {
    padding-right: 36px;
  }

  .quick-btn-delete {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
    background: var(--danger);
    border: none;
    border-radius: 50%;
    color: white;
    font-size: 14px;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .quick-btn.edit-mode .quick-btn-delete {
    display: flex;
    animation: fadeIn 0.2s ease;
  }

  .quick-btn-add {
    background: var(--bg-card);
    border: 1.5px dashed var(--border);
    color: var(--text-muted);
    padding: 14px 16px;
    border-radius: 14px;
    font-size: 14px;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .quick-btn-add:active {
    transform: scale(0.97);
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Add Item Modal */
  .form-group {
    margin-bottom: 16px;
  }

  .form-label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 8px;
    font-weight: 600;
  }

  .form-input {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 14px 16px;
    border-radius: 12px;
    font-size: 15px;
    outline: none;
    transition: border-color 0.2s ease;
    font-family: inherit;
  }

  .form-input:focus {
    border-color: var(--accent);
  }

  .emoji-picker {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .emoji-option {
    width: 44px;
    height: 44px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .emoji-option:active {
    transform: scale(0.92);
  }

  .emoji-option.selected {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  /* Template selector (onboarding) */
  .template-card {
    background: var(--bg);
    border: 2px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .template-card:active {
    transform: scale(0.98);
  }

  .template-card.selected {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .template-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .template-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .template-items {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .template-chip {
    background: rgba(255,255,255,0.05);
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 11px;
    color: var(--text-muted);
  }

  /* Primary Buttons */
  .primary-buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }

  .btn-primary {
    background: var(--accent);
    color: #1A1F2A;
    border: none;
    padding: 18px;
    border-radius: 16px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.5px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.2s ease;
  }

  .btn-primary:active { transform: scale(0.98); }

  .btn-secondary {
    background: var(--bg-card);
    color: var(--text);
    border: 1px solid var(--border);
    padding: 16px;
    border-radius: 16px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .btn-secondary:active { transform: scale(0.98); background: var(--bg-elevated); }

  /* Streak Card */
  .streak-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .streak-label {
    font-size: 13px;
    color: var(--text-muted);
  }

  .streak-value {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--accent);
  }

  /* Meal Cards */
  .meal-card {
    background: var(--bg-card);
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 14px;
    border: 1px solid var(--border);
  }

  .meal-emoji {
    width: 44px;
    height: 44px;
    background: var(--bg-elevated);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .meal-info { flex: 1; }
  .meal-name { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
  .meal-time { font-size: 11px; color: var(--text-muted); }
  .meal-kcal { font-size: 13px; font-weight: 700; color: var(--accent); }

  /* Calendar */
  .calendar-month {
    text-align: center;
    margin-bottom: 20px;
  }

  .month-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -1px;
  }

  .month-year {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-top: 4px;
  }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
    margin-bottom: 24px;
  }

  .day-header {
    font-size: 10px;
    text-align: center;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 8px 0;
    font-weight: 600;
  }

  .day-cell {
    aspect-ratio: 1;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    font-size: 11px;
  }

  .day-cell:active { transform: scale(0.95); }

  .day-num {
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
  }

  .day-icon {
    font-size: 12px;
    margin-top: 2px;
    line-height: 1;
  }

  .day-empty { background: transparent; border: none; cursor: default; }
  .day-perfect { background: rgba(111, 207, 151, 0.45); border-color: rgba(111, 207, 151, 0.7); }
  .day-ok { background: rgba(232, 182, 71, 0.45); border-color: rgba(232, 182, 71, 0.7); }
  .day-cheat { background: rgba(235, 87, 87, 0.45); border-color: rgba(235, 87, 87, 0.7); }
  .day-rest { background: rgba(139, 146, 160, 0.08); border-color: rgba(139, 146, 160, 0.2); }
  .day-noinfo { background: rgba(139, 146, 160, 0.05); border-color: rgba(139, 146, 160, 0.15); border-style: dashed; }
  .day-today { border-color: var(--accent); border-width: 2px; }

  /* Calendar Legend */
  .legend {
    background: var(--bg-card);
    border-radius: 14px;
    padding: 16px;
    border: 1px solid var(--border);
  }

  .legend-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .legend-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
    font-size: 13px;
  }

  .legend-row:last-child { margin-bottom: 0; }

  .legend-dot {
    width: 18px;
    height: 18px;
    border-radius: 6px;
    flex-shrink: 0;
  }

  /* Bottom Nav */
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 414px;
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-around;
    padding: 12px 0 24px;
    z-index: 100;
    backdrop-filter: blur(20px);
  }

  .nav-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    padding: 8px 16px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 500;
    transition: color 0.2s ease;
    letter-spacing: 0.5px;
  }

  .nav-btn.active { color: var(--accent); }
  .nav-btn-icon { font-size: 20px; }

  /* Chat */
  .chat-container { padding-bottom: 100px; }

  .chat-bubble {
    max-width: 80%;
    padding: 12px 16px;
    border-radius: 18px;
    margin-bottom: 10px;
    font-size: 14px;
    line-height: 1.5;
  }

  .chat-claude {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-bottom-left-radius: 4px;
  }

  .chat-user {
    background: var(--accent);
    color: #1A1F2A;
    margin-left: auto;
    border-bottom-right-radius: 4px;
    font-weight: 500;
  }

  .chat-input-area {
    position: fixed;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 414px;
    padding: 12px 24px;
    background: var(--bg);
    border-top: 1px solid var(--border);
    display: flex;
    gap: 8px;
  }

  .chat-input {
    flex: 1;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 12px 16px;
    border-radius: 24px;
    font-size: 14px;
    outline: none;
  }

  .voice-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    color: #1A1F2A;
    font-size: 18px;
    cursor: pointer;
    flex-shrink: 0;
  }

  /* Add Meal Modal */
  .modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    display: none;
    align-items: flex-end;
    justify-content: center;
    z-index: 200;
    backdrop-filter: blur(8px);
  }

  .modal.active { display: flex; animation: fadeIn 0.2s ease; }

  .modal-content {
    background: var(--bg-card);
    width: 100%;
    max-width: 414px;
    border-radius: 28px 28px 0 0;
    padding: 24px;
    animation: slideUp 0.3s ease;
    max-height: 85vh;
    overflow-y: auto;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  .modal-handle {
    width: 36px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    margin: 0 auto 20px;
  }

  .modal-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .modal-subtitle {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .photo-zone {
    border: 2px dashed var(--border);
    border-radius: 20px;
    padding: 40px 20px;
    text-align: center;
    background: var(--bg);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .photo-zone:active { background: var(--bg-elevated); border-color: var(--accent); }

  .photo-icon {
    font-size: 48px;
    margin-bottom: 12px;
    opacity: 0.6;
  }

  .photo-text {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .photo-hint {
    font-size: 12px;
    color: var(--text-muted);
  }

  .analyzed-result {
    margin-top: 20px;
    padding: 16px;
    background: var(--bg);
    border-radius: 16px;
    border: 1px solid var(--accent-soft);
    display: none;
  }

  .analyzed-result.show { display: block; animation: fadeIn 0.4s ease; }

  .analyzed-name {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--accent);
  }

  .analyzed-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 16px;
  }

  .analyzed-item {
    background: var(--bg-card);
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 12px;
  }

  .analyzed-item strong {
    display: block;
    font-size: 18px;
    color: var(--accent);
    font-family: 'Playfair Display', serif;
    margin-top: 2px;
  }

  /* Profile Page */
  .profile-section {
    background: var(--bg-card);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 16px;
    border: 1px solid var(--border);
  }

  .profile-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }

  .profile-row:last-child { border-bottom: none; }

  .profile-label { font-size: 13px; color: var(--text-muted); }
  .profile-value { font-size: 14px; font-weight: 600; }

  /* Weekly Recap Card */
  .recap-card {
    background: linear-gradient(135deg, #2A1F3A 0%, #1F1A2A 100%);
    border-radius: 20px;
    padding: 24px;
    margin-bottom: 16px;
    border: 1px solid var(--border);
  }

  .recap-week {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .recap-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .recap-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 16px;
  }

  .recap-stat {
    background: rgba(255,255,255,0.04);
    padding: 12px 14px;
    border-radius: 10px;
  }

  .recap-stat-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .recap-stat-value {
    font-size: 18px;
    font-weight: 700;
    font-family: 'Playfair Display', serif;
  }

  .recap-stat-value.green { color: var(--success); }
