      if (hasData) {
        cell.classList.add(calorieColorClass(kcalByDate[dateStr]));
        kcalLabel = `<div class="day-icon">${kcalByDate[dateStr]}</div>`;
      } else {
        cell.classList.add('day-noinfo');
      }

      if (dateStr === todayStr) cell.classList.add('day-today');

      cell.innerHTML = `<div class="day-num">${d}</div>${kcalLabel}`;

