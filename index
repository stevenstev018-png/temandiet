  function drawChart(history) {
    const svg = document.getElementById('chartSvg');
    svg.innerHTML = `
      <defs>
        <linearGradient id="chartGradient" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" style="stop-color:#E8B647;stop-opacity:0.4" />
          <stop offset="100%" style="stop-color:#E8B647;stop-opacity:0" />
        </linearGradient>
      </defs>
    `;

    if (history.length < 2) {
      // Empty state — show "perlu lebih banyak data"
      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', 160);
      text.setAttribute('y', 100);
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('fill', '#8B92A0');
      text.setAttribute('font-size', '12');
      text.textContent = 'Update lagi buat lihat chart trend';
      svg.appendChild(text);

      // Single dot
      if (history.length === 1) {
        const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        dot.setAttribute('cx', 160);
        dot.setAttribute('cy', 130);
        dot.setAttribute('r', 5);
        dot.setAttribute('class', 'chart-dot');
        svg.appendChild(dot);
      }
      return;
    }

    // Calculate points
    const values = history.map(h => h.value);
    const min = Math.min(...values);
    const max = Math.max(...values);
    const range = max - min || 1;
    const padding = range * 0.15;

    const chartWidth = 280;
    const chartHeight = 140;
    const offsetX = 20;
    const offsetY = 20;

    const points = history.map((h, i) => {
      const x = offsetX + (i / (history.length - 1)) * chartWidth;
      const y = offsetY + chartHeight - ((h.value - min + padding) / (range + 2 * padding)) * chartHeight;
      return { x, y, value: h.value, date: h.date };
    });

    // Draw area
    const areaPath = `M ${points[0].x} ${offsetY + chartHeight} L ${points.map(p => `${p.x} ${p.y}`).join(' L ')} L ${points[points.length-1].x} ${offsetY + chartHeight} Z`;
    const area = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    area.setAttribute('d', areaPath);
    area.setAttribute('class', 'chart-area');
    svg.appendChild(area);

    // Draw line
    const linePath = `M ${points.map(p => `${p.x} ${p.y}`).join(' L ')}`;
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    line.setAttribute('d', linePath);
    line.setAttribute('class', 'chart-line');
    svg.appendChild(line);

    // Draw dots
    points.forEach(p => {
      const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      dot.setAttribute('cx', p.x);
      dot.setAttribute('cy', p.y);
      dot.setAttribute('r', 4);
      dot.setAttribute('class', 'chart-dot');
      svg.appendChild(dot);
    });

    // X-axis labels (first, middle, last)
    const labelIndices = history.length <= 4
      ? history.map((_, i) => i)
      : [0, Math.floor(history.length / 2), history.length - 1];

    labelIndices.forEach(i => {
      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      const label = history[i].date.split(' ').slice(0, 2).join(' '); // "1 Jun"
      text.setAttribute('x', points[i].x);
      text.setAttribute('y', offsetY + chartHeight + 16);
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('class', 'chart-label');
      text.textContent = label;
      svg.appendChild(text);
    });
  }

  function renderHistory(history, unit) {
    const container = document.getElementById('historyList');
    container.innerHTML = '';

    // Reverse to show newest first
    [...history].reverse().forEach((h, idx, arr) => {
      const item = document.createElement('div');
      item.className = 'history-item';

      // Calculate delta from previous entry
      let deltaHtml = '';
      if (idx < arr.length - 1) {
        const diff = h.value - arr[idx + 1].value;
        if (Math.abs(diff) >= 0.1) {
          const cls = diff > 0 ? 'trend-up' : 'trend-down';
          const sign = diff > 0 ? '+' : '';
          deltaHtml = `<span class="history-delta ${cls}">${sign}${diff.toFixed(1)}</span>`;
        }
      }

      const isStart = idx === arr.length - 1;
      item.innerHTML = `
        <div class="history-date">${h.date}${isStart ? ' (start)' : ''}</div>
        <div>
          <span class="history-value">${formatValue(h.value, unit)}</span>
          ${deltaHtml}
        </div>
      `;
      container.appendChild(item);
    });
  }

