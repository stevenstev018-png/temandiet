  // Check if today's best set is a PR vs history
  function checkPR(exercise) {
    if (!exercise.sets || exercise.sets.length === 0) return false;
    const todayMax = Math.max(...exercise.sets.map(s => parseFloat(s.weight) || 0));
    if (todayMax === 0) return false;

    // Check history for same exercise
    let historyMax = 0;
    workoutHistory.forEach(session => {
      session.exercises.forEach(ex => {
        if (ex.name === exercise.name && ex.sets) {
          ex.sets.forEach(s => {
            const w = parseFloat(s.weight) || 0;
            if (w > historyMax) historyMax = w;
          });
        }
      });
    });

    return todayMax > historyMax;
  }

