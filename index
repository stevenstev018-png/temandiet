      btn.className = 'quick-btn' + (editMode ? ' edit-mode' : '');
      btn.innerHTML = `
        <span class="quick-btn-icon">${item.emoji}</span>
        <span>${item.name}</span>
        ${editMode ? `<span class="quick-btn-delete" onclick="deleteItem(${idx}); event.stopPropagation();">×</span>` : ''}
      `;
      btn.onclick = async () => {
        if (!editMode) {
          const saved = await saveMealToDb({
            name: item.name,
            emoji: item.emoji,
            kcal: item.kcal,
            p: item.p,
            c: item.c,
            f: item.f,
            source: 'quick_add'
          });
          if (saved) {
            renderTodayMeals();
          }
        }
      };
      container.appendChild(btn);
    });

    // Add "+" button if under max
    if (quickItems.length < MAX_ITEMS) {
      const addBtn = document.createElement('button');
      addBtn.className = 'quick-btn-add';
      addBtn.innerHTML = `<span>➕</span><span>Tambah quick add</span>`;
      addBtn.onclick = () => openCustomItemModal();
      container.appendChild(addBtn);
    }

    // Show item count in edit mode
    if (editMode && quickItems.length >= MAX_ITEMS) {
      const note = document.createElement('div');
      note.style.cssText = 'grid-column: 1/-1; text-align: center; color: var(--text-muted); font-size: 11px; padding: 8px;';
      note.textContent = `Max ${MAX_ITEMS} items reached`;
      container.appendChild(note);
    }
  }

  function toggleEditMode() {
    editMode = !editMode;
    const toggleBtn = document.getElementById('editToggle');
    toggleBtn.textContent = editMode ? 'Selesai' : 'Edit';
    toggleBtn.classList.toggle('active', editMode);
    renderQuickActions();
  }

  function deleteItem(idx) {
    if (confirm(`Hapus "${quickItems[idx].name}" dari quick add?`)) {
      quickItems.splice(idx, 1);
      renderQuickActions();
    }
  }

  function openCustomItemModal() {
    document.getElementById('customItemModal').classList.add('active');
    // Reset form
    document.getElementById('inputName').value = '';
    document.getElementById('inputKcal').value = '';
    document.getElementById('inputProtein').value = '';
    document.getElementById('inputCarbs').value = '';
    document.getElementById('inputFat').value = '';
    selectedEmoji = '🍗';
    document.querySelectorAll('.emoji-option').forEach(el => {
      el.classList.toggle('selected', el.dataset.emoji === '🍗');
    });
  }

  // Emoji picker
  document.querySelectorAll('.emoji-option').forEach(el => {
    el.onclick = () => {
      document.querySelectorAll('.emoji-option').forEach(e => e.classList.remove('selected'));
      el.classList.add('selected');
      selectedEmoji = el.dataset.emoji;
    };
  });

  function saveCustomItem() {
    const name = document.getElementById('inputName').value.trim();
    const kcal = parseInt(document.getElementById('inputKcal').value) || 0;
    const p = parseInt(document.getElementById('inputProtein').value) || 0;
    const c = parseInt(document.getElementById('inputCarbs').value) || 0;
    const f = parseInt(document.getElementById('inputFat').value) || 0;

    if (!name || !kcal) {
      alert('Nama dan kalori wajib diisi!');
      return;
    }

    if (quickItems.length >= MAX_ITEMS) {
      alert(`Max ${MAX_ITEMS} items. Hapus dulu yang lama.`);
      return;
    }

    quickItems.push({emoji: selectedEmoji, name, kcal, p, c, f});
    document.getElementById('customItemModal').classList.remove('active');
    renderQuickActions();
  }

  // ============ TEMPLATE SELECTOR ============

  function openTemplateModal() {
    document.getElementById('templateModal').classList.add('active');
    document.querySelectorAll('.template-card').forEach(c => {
      c.classList.toggle('selected', c.dataset.template === selectedTemplate);
    });
  }

  function selectTemplate(t) {
    selectedTemplate = t;
    document.querySelectorAll('.template-card').forEach(c => {
      c.classList.toggle('selected', c.dataset.template === t);
    });
  }

  function applyTemplate() {
    if (quickItems.length > 0 && !confirm('Ganti quick add lo dengan template? Item yang ada bakal di-replace.')) {
      return;
    }
    quickItems = [...templates[selectedTemplate]];
    document.getElementById('templateModal').classList.remove('active');
    renderQuickActions();

    // Update active template label
    const templateNames = {
      cutting: 'Cutting 📉',
      bulking: 'Bulking 📈',
      maintain: 'Maintain ⚖️'
    };
    const el = document.getElementById('activeTemplate');
    if (el) el.textContent = templateNames[selectedTemplate];
  }

  // Init
  renderQuickActions();

  // Override closeModalOnBackdrop to support multiple modals
  function openModal() {
    document.getElementById('mealNameInput').value = '';
    document.getElementById('mealKcalInput').value = '';
    document.getElementById('mealProteinInput').value = '';
    document.getElementById('mealCarbsInput').value = '';
    document.getElementById('mealFatInput').value = '';
    document.getElementById('mealModal').classList.add('active');
  }

  function closeModal() {
    document.getElementById('mealModal').classList.remove('active');
  }

  async function submitManualMeal() {
    const name = document.getElementById('mealNameInput').value.trim();
    const kcal = parseInt(document.getElementById('mealKcalInput').value) || 0;
    const protein = parseFloat(document.getElementById('mealProteinInput').value) || 0;
    const carbs = parseFloat(document.getElementById('mealCarbsInput').value) || 0;
    const fat = parseFloat(document.getElementById('mealFatInput').value) || 0;

    if (!name || !kcal) {
      alert('Nama dan kalori wajib diisi');
      return;
    }

    const saved = await saveMealToDb({
      name, kcal, p: protein, c: carbs, f: fat, source: 'manual'
    });

    if (saved) {
      closeModal();
      await renderTodayMeals();
    }
  }

  function closeModalOnBackdrop(e, modalId) {
    if (e.target.classList.contains('modal')) {
      if (modalId) {
        document.getElementById(modalId).classList.remove('active');
      } else {
        closeModal();
      }
    }
  }

  function simulateAnalyze() {
    setTimeout(() => {
      document.getElementById('analyzedResult').classList.add('show');
    }, 800);
  }
</script>

</body>
</html>
