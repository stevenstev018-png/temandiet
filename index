  // Determine color class from total calories vs target
  function calorieColorClass(totalKcal) {
    const target = targetData.target_kcal || 1700;
    if (totalKcal > target) return 'day-cheat';       // merah: over target
    if (totalKcal < KUNING_UNDEREAT) return 'day-ok';  // kuning: undereat bahaya
    return 'day-perfect';                              // hijau: zona defisit sehat
  }

  async function renderCalendar() {
    if (!grid) return;

    // Update header
    document.getElementById('calMonthName').textContent = monthNamesID[calMonth];
    document.getElementById('calMonthYear').textContent = calYear;

    // Clear previous day cells (keep 7 day-header cells)
    const headers = grid.querySelectorAll('.day-header');
    grid.innerHTML = '';
    headers.forEach(h => grid.appendChild(h));

    // Fetch all meals for this month, group by date
    const monthStart = `${calYear}-${String(calMonth+1).padStart(2,'0')}-01`;
    const lastDay = new Date(calYear, calMonth+1, 0).getDate();
    const monthEnd = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(lastDay).padStart(2,'0')}`;

    const kcalByDate = {};
    const { data: meals, error } = await sb
      .from('meals')
      .select('date, calories')
      .gte('date', monthStart)
      .lte('date', monthEnd);

    if (error) {
      console.error('Calendar load error:', JSON.stringify(error));
    } else if (meals) {
      meals.forEach(m => {
        kcalByDate[m.date] = (kcalByDate[m.date] || 0) + (m.calories || 0);
      });
    }

    // First day offset (Sunday = 0)
    const firstDow = new Date(calYear, calMonth, 1).getDay();
    for (let i = 0; i < firstDow; i++) {
      const cell = document.createElement('div');
      cell.className = 'day-cell day-empty';
      grid.appendChild(cell);
    }

    const todayStr = new Date().toISOString().split('T')[0];

    for (let d = 1; d <= lastDay; d++) {
      const dateStr = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const cell = document.createElement('div');
      cell.className = 'day-cell';

      const hasData = kcalByDate[dateStr] !== undefined;
